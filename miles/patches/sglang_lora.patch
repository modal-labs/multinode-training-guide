+def _merge_lora_update_results(results: List[LoRAUpdateOutput]) -> LoRAUpdateOutput:
+    """Aggregate LoRAUpdateOutput responses from `dp_size` first-rank schedulers.
+
+    Every DP rank processes the same broadcast request with identical tensors and
+    converges to the same `lora_refs` dict, so `loaded_adapters` agrees across
+    ranks. Still AND `success` so a rank-local backend failure cannot be masked
+    by DP-0 succeeding.
+    """
+    all_success = all(r.success for r in results)
+    errors = [r.error_message for r in results if not r.success and r.error_message]
+    merged_error = " | ".join(errors) if errors else None
+    return LoRAUpdateOutput(
+        success=all_success,
+        error_message=merged_error,
+        loaded_adapters=results[0].loaded_adapters if results else None,
+    )
+
+
