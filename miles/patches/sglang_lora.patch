+    def _row_parallel_shard_tp(
+        self, module_name: str, base_model: torch.nn.Module, layer_idx: int
+    ) -> int:
+        """How many ways the row-parallel *input* is partitioned for this module
+        within ``layer_idx``.
+
+        LoRAMemoryPool used to divide by global ``self.tp_size`` for every
+        ``o_proj`` / ``down_proj`` LoRA A buffer.  DeepSeek / Kimi build some
+        ``RowParallelLinear`` layers (notably ``o_proj``) on the **attention**
+        TP group (``attn_tp_size``), which can differ from tensor-parallel world
+        size when DP attention is on.  Then ``A_buffer``'s last dim no longer
+        matches the activation shard and ``chunked_sgmv_lora_shrink_forward``
+        asserts ``x.shape[-1] == K``.
+
+        The factor can also differ **across layers** under the same module_name
+        — e.g. in K2.5 with ``enable_moe_dense_fully_dp=True``, the first
+        ``first_k_dense_replace`` dense layers put ``mlp.down_proj`` on tp_size=1
+        while MoE layers put ``mlp.shared_experts.down_proj`` on the global TP
+        group (tp_size=8). A single global cache produced the wrong size for one
+        of the two groups. Probe and cache per ``(module_name, layer_idx)``.
+
+        Infer the real factor from ``input_size // input_size_per_partition`` on
+        the first matching base module *within the target layer*; fall back to
+        ``self.tp_size`` if no match.
+        """
+        cache = getattr(self, "_row_parallel_tp_cache", None)
+        if cache is None:
+            cache = {}
+            setattr(self, "_row_parallel_tp_cache", cache)
+        key = (module_name, layer_idx)
+        if key in cache:
+            return cache[key]
+
+        def _probe(m):
+            in_size = getattr(m, "input_size", None)
+            per_part = getattr(m, "input_size_per_partition", None)
+            if in_size is not None and per_part is not None and per_part > 0:
+                return max(1, in_size // per_part)
+            inner = getattr(m, "base_layer", None)
+            if inner is not None and inner is not m:
+                return _probe(inner)
+            return None
+
+        suffix = f".{module_name}"
+        layer_markers = (f".layers.{layer_idx}.", f"layers.{layer_idx}.")
+        found = None
+        for _name, module in base_model.named_modules():
+            if not _name.endswith(suffix):
+                continue
+            if not any(marker in _name for marker in layer_markers):
+                continue
+            r = _probe(module)
+            if r is not None:
+                found = r
+                break
+
+        out = found if found is not None else self.tp_size
+        cache[key] = out
+        return out
+
