+class PackedPerExpertLinear(nn.Module):
+    """Per-expert linear with a packed 3D weight ``[N_local, out, in]``.
+
+    Used as the per-expert side of :class:`SharedOuterGroupedExpertAdapter`.
+    Stores one ``nn.Parameter`` (3D) so Bridge's adapter export sees a single
+    ``.weight`` per side (matching the ``adapter.linear_in.weight`` /
+    ``adapter.linear_out.weight`` convention in
+    :mod:`megatron.bridge.models.conversion.peft_bridge`). Forward dispatches
+    to :func:`torch._grouped_mm` — same grouped GEMM kernel TE's
+    :class:`te.pytorch.GroupedLinear` calls, but via a single fused op with
+    native autograd, so we don't need per-expert Python iteration (which
+    desyncs rank kernel launch counts and deadlocks CP's ring P2P).
+
+    .. note::
+        :func:`torch._grouped_mm` is a private API (added in torch 2.9). We
+        guard on ``hasattr`` at construction; consumers targeting older torch
+        would need a ``te.pytorch.general_grouped_gemm`` path here.
+
+    Marks ``.weight`` with ``allreduce=False`` so Megatron-Core's DDP syncs
+    gradients only within ``intra_expt_dp_group`` — each EP rank's per-expert
+    adapter is distinct by construction and should stay that way.
+    """
+
+    def __init__(
+        self,
+        num_local_experts: int,
+        in_features: int,
+        out_features: int,
+        *,
+        init_method: Optional[Callable] = None,
+        dtype: Optional[torch.dtype] = None,
+        device: Optional[torch.device] = None,
+    ):
+        super().__init__()
+        if not hasattr(torch, "_grouped_mm"):
+            raise RuntimeError(
+                "PackedPerExpertLinear requires torch._grouped_mm (torch >= 2.9)."
+            )
+        self.num_local_experts = num_local_experts
+        self.in_features = in_features
+        self.out_features = out_features
+        weight = torch.empty(num_local_experts, out_features, in_features, dtype=dtype, device=device)
+        if init_method is not None:
+            for e in range(num_local_experts):
+                init_method(weight[e])
+        else:
+            nn.init.zeros_(weight)
+        self.weight = nn.Parameter(weight)
+        setattr(self.weight, "allreduce", False)
+
+    def forward(self, x: torch.Tensor, m_splits) -> Tuple[torch.Tensor, None]:
+        # torch._grouped_mm expects mat2 as [num_groups, K, N]; our weight is
+        # [N_local, out, in] so transpose last two dims.
+        if isinstance(m_splits, torch.Tensor):
+            m_splits_i32 = m_splits.to(device=x.device, dtype=torch.int32)
+        else:
+            m_splits_i32 = torch.tensor(m_splits, device=x.device, dtype=torch.int32)
+        offs = torch.cumsum(m_splits_i32, dim=0, dtype=torch.int32)
+        out = torch._grouped_mm(x, self.weight.transpose(1, 2), offs=offs)
+        return out, None
+
+    def sharded_state_dict(self, prefix: str = "", sharded_offsets=(), metadata=None):
+        """Shard the packed 3D weight along dim 0 (experts) across EP ranks.
+
+        Logical shape across the EP group is ``[N_global, out, in]``; each EP
+        rank owns the contiguous ``[ep_rank*N_local : (ep_rank+1)*N_local]``
+        slice. The ``('num_local_experts', ep_rank, ep_size)`` rank-offset
+        makes Megatron's dist-ckpt recognize these as true shards (not
+        replicas) and avoid save collisions.
+        """
+        from megatron.core.dist_checkpointing.mapping import ShardedTensor
+
+        key = f"{prefix}weight"
+        ep_size = parallel_state.get_expert_model_parallel_world_size()
+        if ep_size > 1:
+            ep_rank = parallel_state.get_expert_model_parallel_rank()
+            # The expert dim (dim 0 of the 3D weight) is globally offset by
+            # ep_rank * num_local_experts, and spans ep_size EP shards.
+            shard = ShardedTensor.from_rank_offsets(
+                key,
+                self.weight.data,
+                (0, ep_rank, ep_size),
+                replica_id=(
+                    parallel_state.get_pipeline_model_parallel_rank(),
+                    parallel_state.get_expert_tensor_parallel_rank(),
+                    parallel_state.get_expert_data_parallel_rank(),
+                ),
+            )
+        else:
+            shard = ShardedTensor.from_rank_offsets(
+                key,
+                self.weight.data,
+                replica_id=(
+                    parallel_state.get_pipeline_model_parallel_rank(),
+                    0,
+                    0,
+                ),
+            )
+        return {key: shard}
+
+
+class SharedOuterGroupedExpertAdapter(ParallelLinearAdapter):
+    """LoRA adapter for grouped expert MLP with shared-outer semantics.
+
+    Matches SGLang PR #21466's ``experts_shared_outer_loras=True`` contract:
+
+    * fc1 (gate_up):  linear_in  = SHARED     (hidden -> rank)
+                      linear_out = PER-EXPERT (rank -> 2*intermediate)
+    * fc2 (down):     linear_in  = PER-EXPERT (intermediate -> rank)
+                      linear_out = SHARED     (rank -> hidden)
+
+    **Shared side** uses :class:`StageReplicatedColumnParallelLinear` (fc1)
+    or :class:`StageReplicatedRowParallelLinear` (fc2). Both are ``is_expert=
+    True`` subclasses of Megatron's parallel linear: the TP group is ETP
+    (ETP=1 → local forward), DDP routes through the EDP group, and the
+    logically-replicated cross-EP axis is covered by :class:`SharedGradAllReduce`.
+
+    **Per-expert side** uses :class:`PackedPerExpertLinear` (packed 3D weight
+    + :func:`torch._grouped_mm`) — kept as a single ``.weight`` Parameter so
+    Bridge's adapter-export materializer (which reads ``linear_in.weight`` /
+    ``linear_out.weight``) sees a standard single-weight linear per side.
+
+    Differs from ``ParallelLinearAdapter`` only in ``__init__`` and
+    ``forward``; ``sharded_state_dict`` and scaling behavior are inherited.
+    """
+
+    def __init__(
+        self,
+        in_features: int,
+        out_features: int,
+        dim: int,
+        *,
+        num_local_experts: int,
+        base_linear_name: str,
+        activation: str = "identity",
+        norm_type: Optional[str] = None,
+        column_init_method: str = "xavier",
+        row_init_method: str = "zero",
+        gather_output: bool = False,
+        input_is_parallel: bool = False,
+        dropout: float = 0.0,
+        dropout_position: str = "post",
+        model_parallel_config: Optional[ModelParallelConfig] = None,
+        alpha: Optional[float] = None,
+        a2a_experimental: bool = False,
+        disable_tensor_parallel_comm: bool = False,
+        disable_sequence_parallel_comm: bool = False,
+        base_linear_is_parallel: bool = True,
+    ):
+        nn.Module.__init__(self)
+
+        self._is_fc1 = ".linear_fc1" in base_linear_name
+        if not self._is_fc1:
+            assert ".linear_fc2" in base_linear_name, (
+                f"SharedOuterGroupedExpertAdapter only supports linear_fc1/linear_fc2; "
+                f"got base_linear_name={base_linear_name}"
+            )
+        self.num_local_experts = num_local_experts
+        self.base_linear_name = base_linear_name
+
+        self.activation = self._get_activation_fn(activation)
+        self.dim = dim
+        self.alpha = alpha if alpha is not None else self.dim
+        self.input_is_parallel = input_is_parallel
+        self.dropout_position = dropout_position
+        self.use_a2a = a2a_experimental
+        # is_expert=True keeps ParallelLinearAdapter.sharded_state_dict on the
+        # expert replica_id branch (which we don't fully inherit for our
+        # packed per-expert side, but matches the convention).
+        self.is_expert = True
+
+        if model_parallel_config is None:
+            model_parallel_config = ModelParallelConfig()
+        self.config = model_parallel_config
+
+        if self._is_fc1:
+            # Shared A (hidden → rank): ColumnParallel, ETP-sharded output.
+            self.linear_in = StageReplicatedColumnParallelLinear(
+                in_features,
+                dim,
+                config=model_parallel_config,
+                bias=False,
+                gather_output=True,
+                init_method=self._get_init_fn(column_init_method),
+                is_expert=True,
+            )
+            # Per-expert B (rank → 2*intermediate): packed 3D weight.
+            self.linear_out = PackedPerExpertLinear(
+                num_local_experts=num_local_experts,
+                in_features=dim,
+                out_features=out_features,
+                init_method=self._get_init_fn(row_init_method),
+            )
+        else:
+            # Per-expert A (intermediate → rank): packed 3D weight.
+            self.linear_in = PackedPerExpertLinear(
+                num_local_experts=num_local_experts,
+                in_features=in_features,
+                out_features=dim,
+                init_method=self._get_init_fn(column_init_method),
+            )
+            # Shared B (rank → hidden): RowParallel, ETP-sharded input.
+            self.linear_out = StageReplicatedRowParallelLinear(
+                dim,
+                out_features,
+                config=model_parallel_config,
+                bias=False,
+                input_is_parallel=True,
+                skip_bias_add=True,
+                init_method=self._get_init_fn(row_init_method),
+                is_expert=True,
+            )
+
+        if dropout > 0.0:
+            self.dropout = nn.Dropout(dropout)
+        else:
+            self.dropout = nn.Identity()
+
+        if model_parallel_config.bf16:
+            self.bfloat16()
+        elif model_parallel_config.fp16:
+            self.half()
+
+        self.disable_sequence_parallel_comm = disable_sequence_parallel_comm
+
+        # One-shot broadcast so every rank in the intra-PP-stage group starts
+        # bit-identical. Gradient-side sync during training is owned by
+        # SharedGradAllReduce inside the stage-replicated linear subclasses.
+        shared_weight = self.linear_in.weight if self._is_fc1 else self.linear_out.weight
+        broadcast_across_intra_stage_group(shared_weight.data)
+
+    def forward(self, x: torch.Tensor, m_splits=None) -> torch.Tensor:
+        """Forward. ``m_splits`` is the tokens-per-expert split passed through
+        from the base TEGroupedLinear; required for the per-expert side.
+        """
+        if self.dropout_position == "pre":
+            x = self.dropout(x)
+
+        if self._is_fc1:
+            # Shared A → activation → per-expert B.
+            x, _ = self.linear_in(x)
+            x = self.activation(x)
+            x, _ = self.linear_out(x, m_splits)
+        else:
+            # Per-expert A → activation → shared B.
+            x, _ = self.linear_in(x, m_splits)
+            x = self.activation(x)
+            x, _ = self.linear_out(x)
+
+        if self.dropout_position == "post":
+            x = self.dropout(x)
+
+        return x * (self.alpha / self.dim)
