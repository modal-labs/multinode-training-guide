+class LoRAGroupedExpertLinear(LoRALinear):
+    """LoRALinear for grouped-expert linears (TE*ParallelGroupedLinear).
+
+    The base module's forward takes ``(x, tokens_per_expert)``; the adapter
+    for shared-outer expert LoRA also needs ``tokens_per_expert`` to run its
+    per-expert GroupedLinear side. Plumb it through.
+    """
+
+    # Per-process counter for diagnostic logging (ordered per-layer trace).
+    _MEM_TRACE_COUNTER = 0
+
+    def forward(self, x: torch.Tensor, *args: Any, **kwargs: Any) -> Tuple[torch.Tensor, Optional[torch.Tensor]]:
+        # Diagnostic logging — no-op unless ``MILES_MEM_TRACE=1``.
+        import os as _os
+        _trace = _os.environ.get("MILES_MEM_TRACE", "").strip().lower() not in ("", "0", "false", "no")
+        _tag = ""
+        _rank = 0
+        _alloc0 = _alloc1 = _alloc2 = 0
+        if _trace:
+            LoRAGroupedExpertLinear._MEM_TRACE_COUNTER += 1
+            _tag = f"lora_grouped#{LoRAGroupedExpertLinear._MEM_TRACE_COUNTER}"
+            _alloc0 = torch.cuda.memory_allocated()
+            _rank = torch.distributed.get_rank() if torch.distributed.is_initialized() else 0
+            print(
+                f"[MEM rank={_rank} alloc={_alloc0/1024**3:6.2f}GiB] {_tag} enter "
+                f"x.requires_grad={x.requires_grad} grad_enabled={torch.is_grad_enabled()}",
+                flush=True,
+            )
+
+        linear_output, bias, layernorm_output = self.base_linear_forward(x, *args, **kwargs)
+
+        if _trace:
+            _alloc1 = torch.cuda.memory_allocated()
+            print(
+                f"[MEM rank={_rank} alloc={_alloc1/1024**3:6.2f}GiB Δ={(_alloc1-_alloc0)/1024**3:+.2f}GiB] {_tag} post_base "
+                f"linear_output.requires_grad={linear_output.requires_grad}",
+                flush=True,
+            )
+
+        if not self._adapter_enabled:
+            return linear_output, bias
+        # TEGroupedMLP calls linear_fc1(x, tokens_per_expert) positionally.
+        m_splits = args[0] if args else kwargs.get("m_splits", kwargs.get("tokens_per_expert"))
+        adapter_output = self.adapter(layernorm_output.contiguous(), m_splits=m_splits)
+        adapter_output = adapter_output.reshape(linear_output.shape)
+
+        if _trace:
+            _alloc2 = torch.cuda.memory_allocated()
+            print(
+                f"[MEM rank={_rank} alloc={_alloc2/1024**3:6.2f}GiB Δ={(_alloc2-_alloc1)/1024**3:+.2f}GiB] {_tag} post_adapter "
+                f"adapter_output.requires_grad={adapter_output.requires_grad}",
+                flush=True,
+            )
+
+        out = linear_output + adapter_output
+        if _trace:
+            _alloc3 = torch.cuda.memory_allocated()
+            print(
+                f"[MEM rank={_rank} alloc={_alloc3/1024**3:6.2f}GiB Δ={(_alloc3-_alloc2)/1024**3:+.2f}GiB] {_tag} post_add "
+                f"out.requires_grad={out.requires_grad} has_grad_fn={out.grad_fn is not None}",
+                flush=True,
+            )
+        return out, bias
+
+
