+    ``forward``; ``sharded_state_dict`` and scaling behavior are inherited.
+    """
+
+    def __init__(
+        self,
+        in_features: int,
+        out_features: int,
+        dim: int,
+        *,
+        num_local_experts: int,
+        base_linear_name: str,
+        activation: str = "identity",
+        norm_type: Optional[str] = None,
+        column_init_method: str = "xavier",
+        row_init_method: str = "zero",
+        gather_output: bool = False,
+        input_is_parallel: bool = False,
+        dropout: float = 0.0,
+        dropout_position: str = "post",
+        model_parallel_config: Optional[ModelParallelConfig] = None,
+        alpha: Optional[float] = None,
+        a2a_experimental: bool = False,
+        disable_tensor_parallel_comm: bool = False,
+        disable_sequence_parallel_comm: bool = False,
+        base_linear_is_parallel: bool = True,
+    ):
+        nn.Module.__init__(self)
+
+        self._is_fc1 = ".linear_fc1" in base_linear_name
+        if not self._is_fc1:
+            assert ".linear_fc2" in base_linear_name, (
+                f"SharedOuterGroupedExpertAdapter only supports linear_fc1/linear_fc2; "
+                f"got base_linear_name={base_linear_name}"
+            )
+        self.num_local_experts = num_local_experts
+        self.base_linear_name = base_linear_name
+
+        self.activation = self._get_activation_fn(activation)
+        self.dim = dim
+        self.alpha = alpha if alpha is not None else self.dim
+        self.input_is_parallel = input_is_parallel
+        self.dropout_position = dropout_position
+        self.use_a2a = a2a_experimental
+        # is_expert=True keeps ParallelLinearAdapter.sharded_state_dict on the
+        # expert replica_id branch (which we don't fully inherit for our
+        # packed per-expert side, but matches the convention).
+        self.is_expert = True
+
+        if model_parallel_config is None:
+            model_parallel_config = ModelParallelConfig()
+        self.config = model_parallel_config
+
+        if self._is_fc1:
+            # Shared A (hidden → rank): ColumnParallel, ETP-sharded output.
+            self.linear_in = StageReplicatedColumnParallelLinear(
+                in_features,
+                dim,
+                config=model_parallel_config,
+                bias=False,
+                gather_output=True,
+                init_method=self._get_init_fn(column_init_method),
+                is_expert=True,
+            )
+            # Per-expert B (rank → 2*intermediate): packed 3D weight.
+            self.linear_out = PackedPerExpertLinear(
+                num_local_experts=num_local_experts,
+                in_features=dim,
+                out_features=out_features,
+                init_method=self._get_init_fn(row_init_method),
+            )
+        else:
+            # Per-expert A (intermediate → rank): packed 3D weight.
+            self.linear_in = PackedPerExpertLinear(
+                num_local_experts=num_local_experts,
+                in_features=in_features,
+                out_features=dim,
+                init_method=self._get_init_fn(column_init_method),
+            )
+            # Shared B (rank → hidden): RowParallel, ETP-sharded input.
+            self.linear_out = StageReplicatedRowParallelLinear(
+                dim,
+                out_features,
+                config=model_parallel_config,
+                bias=False,
+                input_is_parallel=True,
+                skip_bias_add=True,
+                init_method=self._get_init_fn(row_init_method),
+                is_expert=True,
+            )
+
+        if dropout > 0.0:
+            self.dropout = nn.Dropout(dropout)
+        else:
+            self.dropout = nn.Identity()
+
+        if model_parallel_config.bf16:
+            self.bfloat16()
+        elif model_parallel_config.fp16:
+            self.half()
+
+        self.disable_sequence_parallel_comm = disable_sequence_parallel_comm
+
+        # One-shot broadcast so every rank in the intra-PP-stage group starts
+        # bit-identical. Gradient-side sync during training is owned by
+        # SharedGradAllReduce inside the stage-replicated linear subclasses.
+        shared_weight = self.linear_in.weight if self._is_fc1 else self.linear_out.weight
+        broadcast_across_intra_stage_group(shared_weight.data)
+
+    def forward(self, x: torch.Tensor, m_splits=None) -> torch.Tensor:
+        """Forward. ``m_splits`` is the tokens-per-expert split passed through
+        from the base TEGroupedLinear; required for the per-expert side.
+        """
+        if self.dropout_position == "pre":
+            x = self.dropout(x)
+
+        if self._is_fc1:
+            # Shared A → activation → per-expert B.
+            x, _ = self.linear_in(x)
+            x = self.activation(x)
+            x, _ = self.linear_out(x, m_splits)
+        else:
+            # Per-expert A → activation → shared B.
+            x, _ = self.linear_in(x, m_splits)
+            x = self.activation(x)
+            x, _ = self.linear_out(x)
+
+        if self.dropout_position == "post":
+            x = self.dropout(x)
+
+        return x * (self.alpha / self.dim)
