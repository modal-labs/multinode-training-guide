+class PackedPerExpertLinear(nn.Module):
+    """Per-expert linear with a packed 3D weight ``[N_local, out, in]``.
+
+    Used as the per-expert side of :class:`SharedOuterGroupedExpertAdapter`.
+    Stores one ``nn.Parameter`` (3D) so Bridge's adapter export sees a single
+    ``.weight`` per side (matching the ``adapter.linear_in.weight`` /
+    ``adapter.linear_out.weight`` convention in
+    :mod:`megatron.bridge.models.conversion.peft_bridge`). Forward dispatches
+    to :func:`torch._grouped_mm` — same grouped GEMM kernel TE's
+    :class:`te.pytorch.GroupedLinear` calls, but via a single fused op with
+    native autograd, so we don't need per-expert Python iteration (which
+    desyncs rank kernel launch counts and deadlocks CP's ring P2P).
+
+    .. note::
+        :func:`torch._grouped_mm` is a private API (added in torch 2.9). We
+        guard on ``hasattr`` at construction; consumers targeting older torch
+        would need a ``te.pytorch.general_grouped_gemm`` path here.
+
+    Marks ``.weight`` with ``allreduce=False`` so Megatron-Core's DDP syncs
+    gradients only within ``intra_expt_dp_group`` — each EP rank's per-expert
+    adapter is distinct by construction and should stay that way.
+    """
+
+    def __init__(
+        self,
+        num_local_experts: int,
+        in_features: int,
+        out_features: int,
+        *,
+        init_method: Optional[Callable] = None,
+        dtype: Optional[torch.dtype] = None,
+        device: Optional[torch.device] = None,
+    ):
+        super().__init__()
+        if not hasattr(torch, "_grouped_mm"):
+            raise RuntimeError(
+                "PackedPerExpertLinear requires torch._grouped_mm (torch >= 2.9)."
+            )
+        self.num_local_experts = num_local_experts
+        self.in_features = in_features
+        self.out_features = out_features
+        weight = torch.empty(num_local_experts, out_features, in_features, dtype=dtype, device=device)
+        if init_method is not None:
+            for e in range(num_local_experts):
+                init_method(weight[e])
+        else:
+            nn.init.zeros_(weight)
+        self.weight = nn.Parameter(weight)
+        setattr(self.weight, "allreduce", False)
+
+    def forward(self, x: torch.Tensor, m_splits) -> Tuple[torch.Tensor, None]:
+        # torch._grouped_mm expects mat2 as [num_groups, K, N]; our weight is
+        # [N_local, out, in] so transpose last two dims.
+        if isinstance(m_splits, torch.Tensor):
+            m_splits_i32 = m_splits.to(device=x.device, dtype=torch.int32)
+        else:
+            m_splits_i32 = torch.tensor(m_splits, device=x.device, dtype=torch.int32)
+        offs = torch.cumsum(m_splits_i32, dim=0, dtype=torch.int32)
+        out = torch._grouped_mm(x, self.weight.transpose(1, 2), offs=offs)
+        return out, None
+
+    def sharded_state_dict(self, prefix: str = "", sharded_offsets=(), metadata=None):
+        """Shard the packed 3D weight along dim 0 (experts) across EP ranks.
+
+        Logical shape across the EP group is ``[N_global, out, in]``; each EP
+        rank owns the contiguous ``[ep_rank*N_local : (ep_rank+1)*N_local]``
+        slice. The ``('num_local_experts', ep_rank, ep_size)`` rank-offset
+        makes Megatron's dist-ckpt recognize these as true shards (not
+        replicas) and avoid save collisions.
+        """
+        from megatron.core.dist_checkpointing.mapping import ShardedTensor
+
+        key = f"{prefix}weight"
+        ep_size = parallel_state.get_expert_model_parallel_world_size()
+        if ep_size > 1:
+            ep_rank = parallel_state.get_expert_model_parallel_rank()
+            # The expert dim (dim 0 of the 3D weight) is globally offset by
+            # ep_rank * num_local_experts, and spans ep_size EP shards.
+            shard = ShardedTensor.from_rank_offsets(
+                key,
+                self.weight.data,
+                (0, ep_rank, ep_size),
+                replica_id=(
+                    parallel_state.get_pipeline_model_parallel_rank(),
+                    parallel_state.get_expert_tensor_parallel_rank(),
+                    parallel_state.get_expert_data_parallel_rank(),
+                ),
+            )
+        else:
+            shard = ShardedTensor.from_rank_offsets(
+                key,
+                self.weight.data,
+                replica_id=(
+                    parallel_state.get_pipeline_model_parallel_rank(),
+                    0,
+                    0,
+                ),
+            )
+        return {key: shard}
+
+
+class SharedOuterGroupedExpertAdapter(ParallelLinearAdapter):
+    """LoRA adapter for grouped expert MLP with shared-outer semantics.
+
+    Matches SGLang PR #21466's ``experts_shared_outer_loras=True`` contract:
+
+    * fc1 (gate_up):  linear_in  = SHARED     (hidden -> rank)
+                      linear_out = PER-EXPERT (rank -> 2*intermediate)
+    * fc2 (down):     linear_in  = PER-EXPERT (intermediate -> rank)
+                      linear_out = SHARED     (rank -> hidden)
