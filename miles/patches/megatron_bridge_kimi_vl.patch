+class SharedGradAllReduce(torch.autograd.Function):
+    """Identity forward; backward averages the grad across the intra-PP-stage
+    group (``tensor_and_data_parallel_group`` with CP = TP×DP×CP, which by
+    Megatron's construction equals ETP×EP×EDP = all ranks in this stage).
+
+    Used to keep a logically-replicated weight in sync across EP replicas
+    that Megatron's default DDP paths don't cover: neither ``allreduce=True``
+    (reduces over dp_cp only) nor ``allreduce=False`` (reduces over EDP
+    only) spans the full intra-stage set.
+
+    Mirrors the :class:`_All2AllHp2Sp` pattern in this file: a custom
+    ``torch.autograd.Function`` for a distributed collective Megatron-Core
+    has no native primitive for.
+    """
+
+    @staticmethod
+    def forward(ctx, weight: torch.Tensor) -> torch.Tensor:
+        return weight
+
+    @staticmethod
+    def backward(ctx, grad_output: torch.Tensor) -> torch.Tensor:
+        if grad_output is None:
+            return None
+        group = parallel_state.get_tensor_and_data_parallel_group(with_context_parallel=True)
+        if torch.distributed.get_world_size(group=group) > 1:
+            grad = grad_output.contiguous()
+            torch.distributed.all_reduce(grad, op=torch.distributed.ReduceOp.AVG, group=group)
+            return grad
+        return grad_output
+
+
+def broadcast_across_intra_stage_group(weight: torch.Tensor) -> None:
+    """One-shot broadcast from group rank 0 so replicas start bit-identical.
+
+    Called once per adapter ``__init__`` so that despite per-rank
+    initialization (different RNG state), every rank in the intra-PP-stage
+    group holds the same initial weight. Gradient sync during training is
+    handled by :class:`SharedGradAllReduce`.
+    """
+    if not torch.distributed.is_available() or not torch.distributed.is_initialized():
+        return
+    try:
+        group = parallel_state.get_tensor_and_data_parallel_group(with_context_parallel=True)
+    except AssertionError:
+        return
+    if torch.distributed.get_world_size(group=group) <= 1:
+        return
+    if not weight.is_cuda:
+        # NCCL requires CUDA tensors; if construction is pre-GPU, skip the
+        # broadcast and rely on deterministic init matching across ranks.
+        return
+    src_rank = torch.distributed.get_global_rank(group, 0)
+    with torch.no_grad():
+        torch.distributed.broadcast(weight, src=src_rank, group=group)
+
+
+class StageReplicatedColumnParallelLinear(ColumnParallelLinear):
+    """:class:`ColumnParallelLinear` whose weight gradient is averaged across
+    the intra-PP-stage group in backward, keeping a logically-replicated
+    weight in sync across EP replicas.
+
+    Construct with ``is_expert=True`` so the underlying TP group is the ETP
+    group (ETP=1 ⇒ local forward; ETP>1 ⇒ native ETP column sharding).
+    ``allreduce=False`` is set automatically by the parent (line ~902 of
+    ``megatron/core/tensor_parallel/layers.py``) → DDP routes the weight
+    through ``intra_expt_dp_group``, and the cross-EP axis is covered by
+    :class:`SharedGradAllReduce`.
+    """
+
+    def forward(self, input_, weight=None, runtime_gather_output=None):
+        if weight is None:
+            weight = self.weight
+        return super().forward(
+            input_,
+            weight=SharedGradAllReduce.apply(weight),
+            runtime_gather_output=runtime_gather_output,
+        )
+
+
+class StageReplicatedRowParallelLinear(RowParallelLinear):
+    """Row-parallel twin of :class:`StageReplicatedColumnParallelLinear`.
