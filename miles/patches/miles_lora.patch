diff --git a/miles/utils/memory_probe.py b/miles/utils/memory_probe.py
new file mode 100644
index 000000000..d01f894e8
--- /dev/null
+++ b/miles/utils/memory_probe.py
@@ -0,0 +1,154 @@
+"""Fine-grained GPU memory timeline logging.
+
+Companion to :mod:`miles.utils.memory_profile` (which dumps full snapshots on
+OOM). This module prints lightweight tag-based memory samples so you can see
+WHICH step / layer / phase is growing memory without needing to open a pickle.
+
+Enable with ``MILES_MEM_TRACE=1``. Optionally throttle noisy callers with
+``MILES_MEM_TRACE_EVERY_N=<int>`` (default 1: every call). Output goes to
+stdout with rank tag so you can grep by rank.
+
+Example output:
+  [MEM rank=13 +42.31 GiB / +0.56 GiB res] layer_0_fc1_enter
+  [MEM rank=13 +42.89 GiB / +0.00 GiB res] layer_0_fc1_exit
+  [MEM rank=13 +43.44 GiB / +0.55 GiB res] layer_1_fc1_enter
+
+The "+X" numbers are absolute allocated / reserved in GiB (leading "+" is just
+cosmetic). No prints and zero overhead when the env var is unset.
+"""
+
+from __future__ import annotations
+
+import os
+import threading
+from typing import Optional
+
+
+_ENABLED: Optional[bool] = None
+_EVERY_N: Optional[int] = None
+_COUNTER_LOCK = threading.Lock()
+_COUNTERS: dict[str, int] = {}
+
+
+def _enabled() -> bool:
+    global _ENABLED
+    if _ENABLED is None:
+        v = os.environ.get("MILES_MEM_TRACE", "")
+        _ENABLED = v.strip().lower() not in ("", "0", "false", "no")
+    return _ENABLED
+
+
+def _every_n() -> int:
+    global _EVERY_N
+    if _EVERY_N is None:
+        try:
+            _EVERY_N = max(1, int(os.environ.get("MILES_MEM_TRACE_EVERY_N", "1")))
+        except ValueError:
+            _EVERY_N = 1
+    return _EVERY_N
+
+
+def _should_fire(tag: str) -> bool:
+    every = _every_n()
+    if every == 1:
+        return True
+    with _COUNTER_LOCK:
+        n = _COUNTERS.get(tag, 0) + 1
+        _COUNTERS[tag] = n
+    return (n % every) == 1
+
+
+def log_memory(tag: str, extra: str = "") -> None:
+    """Print current GPU memory with ``tag`` to stdout, one line.
+
+    No-op when ``MILES_MEM_TRACE`` is unset. Uses
+    :func:`torch.cuda.memory_allocated` / ``memory_reserved`` (both cheap,
+    on-host counters; no CUDA sync).
+    """
+    if not _enabled():
+        return
+    if not _should_fire(tag):
+        return
+    try:
+        import torch
+        import torch.distributed as dist
+    except Exception:
+        return
+    if not torch.cuda.is_available():
+        return
+    rank = dist.get_rank() if dist.is_initialized() else 0
+    alloc_gib = torch.cuda.memory_allocated() / (1024**3)
+    res_gib = torch.cuda.memory_reserved() / (1024**3)
+    suffix = f"  {extra}" if extra else ""
+    print(
+        f"[MEM rank={rank} alloc={alloc_gib:6.2f}GiB reserved={res_gib:6.2f}GiB] {tag}{suffix}",
+        flush=True,
+    )
+
+
+def log_delta(tag: str, start_alloc_bytes: int) -> None:
+    """Log memory delta since ``start_alloc_bytes``. Use for scope enter/exit."""
+    if not _enabled():
+        return
+    if not _should_fire(tag + "__delta"):
+        return
+    try:
+        import torch
+        import torch.distributed as dist
+    except Exception:
+        return
+    if not torch.cuda.is_available():
+        return
+    rank = dist.get_rank() if dist.is_initialized() else 0
+    now = torch.cuda.memory_allocated()
+    delta_gib = (now - start_alloc_bytes) / (1024**3)
+    print(
+        f"[MEM rank={rank} Δ={delta_gib:+6.2f}GiB alloc={now/1024**3:6.2f}GiB] {tag}",
+        flush=True,
+    )
+
+
+class scope:  # noqa: N801 — lowercase for `with memory_probe.scope("..."):`
+    """Context manager that prints enter/exit memory deltas for a region.
+
+    ``with scope("my_tag"): ...`` prints on enter and exit (with delta). Zero
+    overhead when disabled — short-circuits immediately.
+    """
+
+    __slots__ = ("tag", "_start")
+
+    def __init__(self, tag: str):
+        self.tag = tag
+        self._start: Optional[int] = None
+
+    def __enter__(self):
+        if not _enabled():
+            return self
+        try:
+            import torch
+        except Exception:
+            return self
+        if not torch.cuda.is_available():
+            return self
+        self._start = torch.cuda.memory_allocated()
+        log_memory(f"{self.tag}::enter")
+        return self
+
+    def __exit__(self, exc_type, exc, tb):
+        if not _enabled() or self._start is None:
+            return False
+        log_delta(f"{self.tag}::exit", self._start)
+        return False
+
+
+def memory_allocated_bytes() -> int:
+    """Best-effort current allocated bytes; 0 when disabled / no CUDA."""
+    if not _enabled():
+        return 0
+    try:
+        import torch
+    except Exception:
+        return 0
+    if not torch.cuda.is_available():
+        return 0
+    return torch.cuda.memory_allocated()
diff --git a/miles/utils/memory_profile.py b/miles/utils/memory_profile.py
new file mode 100644
index 000000000..63e0477ef
--- /dev/null
+++ b/miles/utils/memory_profile.py
@@ -0,0 +1,104 @@
+"""Lightweight CUDA memory profiling via ``torch.cuda.memory._record_memory_history``.
+
+Enable with ``MILES_MEMORY_PROFILE=1`` (snapshots land in ``/data/memsnaps``)
+or override the output directory with ``MILES_MEMORY_PROFILE_DIR=/some/path``.
+Snapshots are dumped as ``memsnap_rank{N}_{tag}.pickle`` files viewable at
+https://pytorch.org/memory_viz — drag-drop the pickle to get an interactive
+timeline of every alloc / free and the Python stack that made it.
+
+Typical flow:
+  1. :func:`enable_memory_history` once at model setup.
+  2. :func:`dump_memory_snapshot("step-N-oom")` inside an ``except
+     torch.cuda.OutOfMemoryError`` block, before re-raising.
+
+Recording is a no-op when neither env var is set (zero overhead).
+"""
+
+from __future__ import annotations
+
+import logging
+import os
+from typing import Optional
+
+logger = logging.getLogger(__name__)
+
+_DEFAULT_OUTPUT_DIR = "/data/memsnaps"
+
+_ENABLED: Optional[bool] = None
+_OUTPUT_DIR: Optional[str] = None
+_RECORDING_STARTED: bool = False
+
+
+def _truthy(value: Optional[str]) -> bool:
+    return value is not None and value.strip().lower() not in {"", "0", "false", "no"}
+
+
+def _resolve_settings() -> None:
+    """Resolve the enable flag and output directory once."""
+    global _ENABLED, _OUTPUT_DIR
+    if _ENABLED is not None:
+        return
+    override_dir = os.environ.get("MILES_MEMORY_PROFILE_DIR")
+    enable_flag = _truthy(os.environ.get("MILES_MEMORY_PROFILE"))
+    if override_dir:
+        _ENABLED = True
+        _OUTPUT_DIR = override_dir
+    elif enable_flag:
+        _ENABLED = True
+        _OUTPUT_DIR = _DEFAULT_OUTPUT_DIR
+    else:
+        _ENABLED = False
+        _OUTPUT_DIR = None
+
+
+def _enabled() -> bool:
+    _resolve_settings()
+    return bool(_ENABLED)
+
+
+def enable_memory_history(max_entries: int = 200_000) -> None:
+    """Start recording CUDA allocator history. Idempotent; no-op if disabled."""
+    global _RECORDING_STARTED
+    if not _enabled() or _RECORDING_STARTED:
+        return
+    import torch
+
+    if not torch.cuda.is_available():
+        return
+    torch.cuda.memory._record_memory_history(max_entries=max_entries)
+    _RECORDING_STARTED = True
+    logger.info("CUDA memory history recording enabled (max_entries=%d)", max_entries)
+
+
+def dump_memory_snapshot(tag: str) -> Optional[str]:
+    """Dump the current allocator snapshot to
+    ``<output_dir>/memsnap_rank{N}_{tag}.pickle``.
+
+    Output directory defaults to ``/data/memsnaps`` (override with
+    ``MILES_MEMORY_PROFILE_DIR``). Returns the path (or ``None`` if disabled /
+    failed). All ranks dump — inspect a few to spot cross-rank asymmetry.
+    """
+    if not _enabled():
+        return None
+    import torch
+    import torch.distributed as dist
+
+    if not torch.cuda.is_available():
+        return None
+
+    out_dir = _OUTPUT_DIR or _DEFAULT_OUTPUT_DIR
+    try:
+        os.makedirs(out_dir, exist_ok=True)
+    except OSError as e:
+        logger.warning("cannot create memory profile dir %s: %s", out_dir, e)
+        return None
+
+    rank = dist.get_rank() if dist.is_initialized() else 0
+    path = os.path.join(out_dir, f"memsnap_rank{rank}_{tag}.pickle")
+    try:
+        torch.cuda.memory._dump_snapshot(path)
+    except Exception as e:  # noqa: BLE001
+        logger.warning("memory snapshot dump (%s) failed: %s", path, e)
+        return None
+    logger.info("CUDA memory snapshot dumped to %s", path)
+    return path
