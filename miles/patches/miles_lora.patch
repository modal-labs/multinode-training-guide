+def wrap_model_provider_with_freeze(original_provider, args: argparse.Namespace):
+    def wrapped_provider(pre_process=True, post_process=True, vp_stage=None, config=None, pg_collection=None):
+        sig = inspect.signature(original_provider)
+        call_kwargs: dict = {"pre_process": pre_process, "post_process": post_process}
+        for key, val in (
+            ("vp_stage", vp_stage),
+            ("config", config),
+            ("pg_collection", pg_collection),
+        ):
+            if key in sig.parameters:
+                call_kwargs[key] = val
+        model = original_provider(**call_kwargs)
+
+        freeze_model_params(model, args)
+
+        return model
+
+    return wrapped_provider
+
+
+def freeze_model_params(model, args: argparse.Namespace) -> None:
+    """Set requires_grad from --only-train-params-name-list / --freeze-params-name-list (regex, re.search on name)."""
+    if not getattr(args, "only_train_params_name_list", None) and not getattr(args, "freeze_params_name_list", None):
+        return
+
+    modules = model if isinstance(model, (list, tuple)) else [model]
+
+    if args.only_train_params_name_list:
+        for mod in modules:
+            for name, param in mod.named_parameters():
+                param.requires_grad = False
+                for pattern in args.only_train_params_name_list:
+                    if re.search(pattern, name):
+                        param.requires_grad = True
+                        break
+
+    if args.freeze_params_name_list:
+        for mod in modules:
+            for name, param in mod.named_parameters():
+                for pattern in args.freeze_params_name_list:
+                    if re.search(pattern, name):
+                        param.requires_grad = False
+                        break
